# Local LLM API (OpenAI-compatible)
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=your-api-key
LLM_MODEL=kimi-k2.5
LLM_SYSTEM_PROMPT=You are a helpful assistant.

# Cube Platform
CUBE_API_TOKEN=your-cube-token
CUBE_API_URL=https://cube.example.com/api

# Flask
FLASK_PORT=5000

# Redis (primary -> fallback order, leave both empty for in-memory fallback)
REDIS_URL=redis://:skewRedis!2@10.156.133.129:10108/0
REDIS_FALLBACK_URL=redis://:afmWebapp!001@10.156.133.126:10121/0

# Conversation limits
CONVERSATION_MAX_MESSAGES=20
CONVERSATION_TTL_SECONDS=3600

# Workspace / PVC (Linux release defaults)
WORKSPACE_ROOT=/project/workSpace
PVC_ROOT=/project/workSpace/pvc/download

# CDN
CDN_STORAGE_DIR=/project/workSpace/pvc/download/cdn/images
CDN_BASE_URL=http://localhost:5000/cdn/images
CDN_MAX_UPLOAD_BYTES=10485760
CDN_ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp
CDN_IMAGE_TTL_SECONDS=0
CDN_REDIS_URL=redis://:afmWebapp!001@10.156.133.126:10121/0

# Chart images
CHART_IMAGE_DIR=./data/chart-images
CHART_IMAGE_BASE_URL=http://localhost:5000/static/charts
