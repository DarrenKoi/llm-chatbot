# Local LLM API (OpenAI-compatible)
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=your-api-key
LLM_MODEL=kimi-k2.5
LLM_SYSTEM_PROMPT_OVERRIDE=
LLM_TIMEOUT_SECONDS=30

# Cube Platform
CUBE_API_ID=C0000143
CUBE_API_TOKEN=your-cube-token
CUBE_API_URL=http://cube.skhynix.com:8888
CUBE_MULTIMESSAGE_URL=http://cube.skhynix.com:8888/api/multiMessage
CUBE_RICHNOTIFICATION_URL=http://cube.skhynix.com:8888/legacy/richnotification
CUBE_RICHNOTIFICATION_CALLBACK_URL=${WEB_APP_URL}/api/v1/cube/richnotification/callback
CUBE_BOT_NAME=ITC OSS
CUBE_BOT_USERNAMES=ITC OSS
CUBE_TIMEOUT_SECONDS=10
CUBE_QUEUE_NAME=cube:incoming
CUBE_QUEUE_PROCESSING_NAME=cube:incoming:processing
CUBE_MESSAGE_DEDUP_TTL_SECONDS=3600
CUBE_QUEUE_BLOCK_TIMEOUT_SECONDS=5
CUBE_QUEUE_MAX_RETRIES=3
CUBE_WORKER_RETRY_DELAY_SECONDS=5

# Flask
FLASK_PORT=5000
APP_NAME=llm_chatbot
APP_ENV=development

# MCP
ITC_MCP_SERVER_DEV_ENDPOINT=http://itc-1stop-solution-mcp-basic-dev.api.hcpnd01.skhynix.com
ITC_MCP_SERVER_PRD_ENDPOINT=http://itc-1stop-solution-mcp-basic-prd.api.hcpp01.skhynix.com
ITC_MCP_SERVER_ID=ITC_OSS_MCP
ITC_MCP_SERVER_ENABLED=True

# Redis (leave empty for in-memory fallback)
REDIS_URL=redis://:afmWebapp!001@10.156.133.126:10121/0

# MongoDB (leave empty for in-memory conversation fallback)
AFM_MONGO_URI=
AFM_DB_NAME=itc-afm-data-platform-mongodb
CONVERSATION_COLLECTION_NAME=cube_conversation_history
LANGGRAPH_CHECKPOINT_COLLECTION_NAME=cube_checkpoints
LANGGRAPH_CHECKPOINT_WRITES_COLLECTION_NAME=cube_checkpoint_writes
CHECKPOINT_TTL_SECONDS=259200

# Conversation limits
CONVERSATION_MAX_MESSAGES=5
CONVERSATION_TTL_SECONDS=0

# Scheduler (distributed lock + strict job control)
SCHEDULER_REDIS_URL=redis://:afmWebapp!001@10.156.133.126:10121/0
SCHEDULER_LOCK_PREFIX=scheduler:llm_chatbot
SCHEDULER_LOCK_TTL_SECONDS=3600
SCHEDULER_LOCK_RENEW_INTERVAL_SECONDS=30
SCHEDULER_JOB_MISFIRE_GRACE_SECONDS=60
SCHEDULER_WORKER_IDLE_SECONDS=60

# Logging
LOG_DIR=./logs
LOG_TIMEZONE=Asia/Seoul
ACTIVITY_LOG_THEME=activity
LOG_RETENTION_DAYS=7
ACTIVITY_LOG_MAX_BYTES=20971520
ACTIVITY_LOG_BACKUP_COUNT=30
TOPIC_LOG_MAX_BYTES=10485760
TOPIC_LOG_BACKUP_COUNT=14

# Workspace (Linux release defaults)
WORKSPACE_ROOT=/project/workSpace
WEB_APP_URL=http://itc-1stop-solution-llm-webapp.aipp02.skhynix.com

# File delivery
FILE_DELIVERY_STORAGE_DIR=/project/workSpace/itc-1stop-solution-pjt-shared/file_delivery
FILE_DELIVERY_BASE_URL=${WEB_APP_URL}/file-delivery/files
FILE_DELIVERY_MAX_UPLOAD_BYTES=10485760
FILE_DELIVERY_STORAGE_LIMIT_BYTES=8589934592
FILE_DELIVERY_ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp,xlsx,pptx,docx,txt,pdf
FILE_DELIVERY_IMAGE_TTL_SECONDS=0
FILE_DELIVERY_REDIS_URL=redis://:afmWebapp!001@10.156.133.126:10121/0
FILE_DELIVERY_RETENTION_DAYS=21
FILE_DELIVERY_CLEANUP_HOUR=1
FILE_DELIVERY_CLEANUP_MINUTE=0
FILE_DELIVERY_MAX_RESIZE_WIDTH=2048
FILE_DELIVERY_MAX_RESIZE_HEIGHT=2048
FILE_DELIVERY_THUMBNAIL_WIDTH=320
FILE_DELIVERY_THUMBNAIL_HEIGHT=320
