# Local LLM API (OpenAI-compatible)
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=your-api-key
LLM_MODEL=kimi-k2.5
LLM_SYSTEM_PROMPT=You are a helpful assistant.

# Cube Platform
CUBE_API_TOKEN=your-cube-token
CUBE_API_URL=https://cube.example.com/api

# Flask
FLASK_PORT=5000

# Redis (primary -> fallback order, leave both empty for in-memory fallback)
REDIS_URL=redis://:afmWebapp!001@10.156.133.126:10121/0
REDIS_FALLBACK_URL=redis://:skewRedis!2@10.156.133.129:10108/0

# Conversation limits
CONVERSATION_MAX_MESSAGES=20
CONVERSATION_TTL_SECONDS=3600

# Scheduler (distributed lock + strict job control)
SCHEDULER_REDIS_URL=redis://:afmWebapp!001@10.156.133.126:10121/0
SCHEDULER_LOCK_PREFIX=scheduler:sknn_v3
SCHEDULER_LOCK_TTL_SECONDS=3600
SCHEDULER_LOCK_RENEW_INTERVAL_SECONDS=30
SCHEDULER_JOB_MISFIRE_GRACE_SECONDS=60

# Workspace / PVC (Linux release defaults)
WORKSPACE_ROOT=/project/workSpace
PVC_ROOT=/project/workSpace/pvc/download

# CDN
CDN_STORAGE_DIR=/project/workSpace/pvc/download/cdn/files
CDN_BASE_URL=http://localhost:5000/cdn/files
CDN_MAX_UPLOAD_BYTES=10485760
CDN_STORAGE_LIMIT_BYTES=8589934592
CDN_ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp,xlsx,pptx,docx
CDN_IMAGE_TTL_SECONDS=0
CDN_REDIS_URL=redis://:afmWebapp!001@10.156.133.126:10121/0
CDN_RETENTION_DAYS=30
CDN_MAX_RESIZE_WIDTH=2048
CDN_MAX_RESIZE_HEIGHT=2048
CDN_THUMBNAIL_WIDTH=320
CDN_THUMBNAIL_HEIGHT=320

# Chart images
CHART_IMAGE_DIR=./data/chart-images
CHART_IMAGE_BASE_URL=http://localhost:5000/static/charts
